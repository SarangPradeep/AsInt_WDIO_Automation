<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Asset Inspection Functional Test"
	parallel="false"
	verbose="1"
	configfailurepolicy="continue">

	<listeners>
		<listener class-name="com.qa.flp.listeners.TestAllureListener" />
	</listeners>

	<test name="Asset Inspection Functional Test">
		<!-- Browser injected from CI via -Dbrowser -->
		<parameter name="browser" value="${browser}" />
		<classes>
			<class name="com.qa.flp.tests.FunctionalTest" />
		</classes>
	</test>

</suite>
