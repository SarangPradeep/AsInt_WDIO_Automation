<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Asset Inspection Negative Test– Multi Browser Parallel" parallel="tests"
	thread-count="2" verbose="1" configfailurepolicy="continue"> <!-- CHROME -->

	<listeners>
		<listener class-name="com.qa.flp.listeners.TestAllureListener"></listener>

	</listeners>
	<test name="Asset Inspection Negative Test - Chrome">
		<parameter name="browser" value="chrome" />
		<classes>
			<class name="com.qa.flp.tests.NegativeTest" />
		</classes>
	</test> <!--
	EDGE -->
	<test name="Asset Inspection Negative Test - edge">
		<parameter name="browser" value="edge" />
		<classes>
			<class name="com.qa.flp.tests.NegativeTest" />
		</classes>
	</test>
</suite>