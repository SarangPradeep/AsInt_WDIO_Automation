<?xml version="1.0" encoding="UTF-8"?>

<suite name="Asset Inspection Regression Test"
	parallel="false"
	verbose="1"
	configfailurepolicy="continue">

	<listeners>
		<listener class-name="com.qa.flp.listeners.TestAllureListener" />
	</listeners>

	<test name="Asset Inspection Regression Test">
		<!-- Browser injected from CI using -Dbrowser -->
		<parameter name="browser" value="${browser}" />
		<classes>
			<class name="com.qa.flp.tests.RegressionTest" />
		</classes>
	</test>

</suite>
