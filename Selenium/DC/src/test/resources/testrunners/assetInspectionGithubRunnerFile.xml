<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Asset Inspection Suite"
	parallel="false"
	verbose="1"
	configfailurepolicy="continue">

	<test name="Asset Inspection Tests">
		<!-- Browser is injected from GitHub Actions -->
		<parameter name="browser" value="${browser}" />
		<classes>
			<class name="com.qa.flp.tests.AssetInspectionTest" />
		</classes>
	</test>

</suite>
