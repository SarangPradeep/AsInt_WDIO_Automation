<?xml version="1.0" encoding="UTF-8"?>

<suite name="GCP Functional Test"
	parallel="false"
	verbose="1"
	configfailurepolicy="continue">

	<listeners>
		<listener class-name="com.qa.gcp.listeners.TestAllureListener" />
	</listeners>

	<test name="GCP Functional Test">
		<!-- Browser injected from CI using -Dbrowser -->
		<parameter name="browser" value="${browser}" />
		<classes>
			<class name="com.qa.gcp.tests.FunctionalGCPTest" />
		</classes>
	</test>

</suite>
