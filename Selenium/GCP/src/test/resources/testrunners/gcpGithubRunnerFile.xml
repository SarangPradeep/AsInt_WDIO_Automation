<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="GCP Regression – Multi Browser Parallel"
	parallel="tests"
	thread-count="2"
	verbose="1"
	configfailurepolicy="continue">

	<listeners>
		<listener class-name="com.qa.gcp.listeners.TestAllureListener" />
	</listeners>

	<test name="GCP Test - Chrome">
		<parameter name="browser" value="chrome" />
		<classes>
			<class name="com.qa.gcp.tests.FunctionalGCPTest" />
			<class name="com.qa.gcp.tests.RegressionGCPTest" />
			<class name="com.qa.gcp.tests.NegativeGCPTest" />
		</classes>
	</test>

	<test name="GCP Test - Edge">
		<parameter name="browser" value="edge" />
		<classes>
			<class name="com.qa.gcp.tests.FunctionalGCPTest" />
			<class name="com.qa.gcp.tests.RegressionGCPTest" />
			<class name="com.qa.gcp.tests.NegativeGCPTest" />
		</classes>
	</test>

</suite>
