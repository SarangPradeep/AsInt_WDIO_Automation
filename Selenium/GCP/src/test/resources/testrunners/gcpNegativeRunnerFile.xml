<?xml version="1.0" encoding="UTF-8"?>

<suite name="GCP Negative Test"
       parallel="false"
       verbose="1"
       configfailurepolicy="continue">

    <listeners>
        <listener class-name="com.qa.gcp.listeners.TestAllureListener" />
    </listeners>

    <test name="GCP Negative Test">
        <!-- Browser injected from CI using -Dbrowser -->
        <parameter name="browser" value="${browser}" />
        <classes>
            <class name="com.qa.gcp.tests.NegativeGCPTest" />
        </classes>
    </test>

</suite>
