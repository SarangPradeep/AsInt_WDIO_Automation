{
  "name": "asint_qa_tool_poc",
  "type": "module",
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.0.9",
    "@wdio/allure-reporter": "^9.23.3",
    "@wdio/cli": "^9.23.2",
    "@wdio/globals": "^9.23.0",
    "@wdio/local-runner": "^9.23.2",
    "@wdio/mocha-framework": "^9.23.2",
    "@wdio/spec-reporter": "^9.23.2",
    "@wdio/visual-service": "^9.1.1",
    "allure-commandline": "^2.36.0",
    "dotenv": "^17.2.3",
    "expect-webdriverio": "^5.6.3",
    "webdriver-manager": "^12.1.9"
  },
  "scripts": {
    "test": "wdio run ./wdio.conf.ts",
    "wdio": "wdio run wdio.conf.ts",
    "wdio:headless": "wdio run ./wdio.conf.ts --headless",
    "wdio:logs": "wdio run ./wdio.conf.ts 2>&1 | findstr /V \"INFO @wdio\" > clean-test.log",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report",
    "report": "npm run report:generate && npm run report:open"
  },
  "dependencies": {
    "edgedriver": "^6.3.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^3.11.174"
  }
}
